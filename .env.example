# URL base de la app (para redirects de auth, TV, etc.)
NEXT_PUBLIC_APP_URL=https://watchily-ho.vercel.app

# Supabase (claves actuales: Publishable + Secret, no legacy anon/service_role)
# Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx
SUPABASE_SECRET_KEY=sb_secret_xxxx

# Streaming APIs (opcional)
WATCHMODE_API_KEY=
STREAMING_AVAILABILITY_API_KEY=

# API docs — Scalar at GET /api-docs (OpenAPI JSON at GET /api/openapi; no env vars required)

# Sentry — https://sentry.io (project: watchily-ho)
# Web/TV: platform tag web or webos (LG webOS via middleware)
SENTRY_DSN=
# Optional — source maps upload on Vercel CI
SENTRY_ORG=
SENTRY_PROJECT=watchily-ho
SENTRY_AUTH_TOKEN=

# Upstash Redis — rate limit on GET /api/titles/search (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest — watchlist availability refresh (https://www.inngest.com/docs/deploy/vercel)
# Alternative: docs/supabase-queues-alternative.md
INNGEST_DEV=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
